POSTGRES_DB=jobsdb
POSTGRES_USER=jobsuser
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://jobsuser:change-me@postgres:5432/jobsdb

API_HOST=0.0.0.0
API_PORT=8000

# Optional generic jobs API endpoint
EXTERNAL_JOBS_API_URL=https://example.com/jobs
FETCH_TIMEOUT_SECONDS=20
RUN_ON_STARTUP=true
CRON_SCHEDULE=0 2 * * *
PAGE_SIZE=100

# France Travail API
FRANCE_TRAVAIL_API_SEARCH=https://api.francetravail.io/partenaire/offresdemploi/v2/offres/search
FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FT_CLIENT_ID=replace-with-client-id
FT_CLIENT_SECRET=replace-with-client-secret
FT_SCOPE=api_offresdemploiv2 o2dsoffre

JOB_API_BASE_URL=http://job-api-service:8000
JOB_INGESTION_BASE_URL=http://job-ingestion-service:8080
UI_HOST=0.0.0.0
UI_PORT=3000
